       1000-INICIO.                                                     00280000
           ACCEPT WS-FECHA FROM DATE.
           MOVE WS-FECHA-AA TO WS-TITULO-ANIO
           MOVE WS-FECHA-MM TO WS-TITULO-MES
           MOVE WS-FECHA-DD TO WS-TITULO-DIA
      
      *REALIZO OPERACIONES PARA GESTIONAR MAS FACILMENTE LOS SALTOS DE
      *PAGINAS LUEGO.
           SUBTRACT 1 FROM WS-MAX-LINEAS
           SUBTRACT 1 FROM WS-MAX-LINEAS-CABEZ

           SET WS-NO-ULTIMA-ITERACION TO TRUE
           SET WS-NO-ES-SALTO-ALT     TO TRUE

           SET WS-NO-FIN TO TRUE                                        00290000
                                                                        00300000
           OPEN OUTPUT SALIDA
           MOVE 'OP' TO WS-OP-GR-CL-FS

           PERFORM 9000-VAL-SAL-FS
              THRU F-9000-VAL-SAL-FS
      *INICIALIZO EN 1 EL CONTADOR DE LINEAS
           MOVE 1 TO WS-CUENTA-LINEA

      *SI VIENE SIN ERRORES INTENTO ABRIR EL CURSOR
           IF WS-NO-FIN
               EXEC SQL
                 OPEN CURSOR-CTA
               END-EXEC
              MOVE 'OP' TO WS-OP-CL-SQL

              PERFORM 10000-SQL-OP-CL-CODE
                 THRU F-10000-SQL-OP-CL-CODE
           END-IF
                                                   
      *SI SEGUIMOS SIN ERRORES HAGO LA PRIMERA LECTURA PARA ENTRAR
      *AL PROGRAMA CON DATOS LEIDOS.
           IF WS-NO-FIN                                                 00391000
              PERFORM 2500-LEER     THRU F-2500-LEER                    00400000
           END-IF         
  
      *Y SI SEGUIMOS BIEN IMPRIMO LOS ENCABEZADOS POR PRIMERA VEZ
           IF RETURN-CODE NOT EQUAL 9999
              IF WS-NO-FIN                                                 00421
                 MOVE WS-TIPCUEN      TO WS-CORTE-MEN-ANT                  00421
                 MOVE WS-SUCUEN       TO WS-CORTE-MAY-ANT                  00421

                 PERFORM 7000-IMP-TITULOS
                    THRU F-7000-IMP-TITULOS

                 PERFORM 8000-IMP-ENCABEZ-SUC
                    THRU F-8000-IMP-ENCABEZ-SUC
              END-IF                                                       00422
           END-IF                                                       00422000
           .                                                            00422000
                                                                        00422000
       F-1000-INICIO.   EXIT.                                           00430000
                                                                        00440000
      **************************************                            00450000
      *                                    *                            00460000
      *  CUERPO PRINCIPAL DE PROCESOS      *                            00470000
      *                                    *                            00480000
      **************************************                            00490000
       2000-PROCESO.                                                    00500000
      *SI EL DATO ACTUAL PERTENECE AL MISMO CORTE MAYOR QUE EL ANTERIOR
           IF WS-SUCUEN = WS-CORTE-MAY-ANT                              00620000
      *Y EL DATO ACTUAL PERTENECE AL MISMO CORTE MENOR QUE EL ANTERIOR
              IF WS-TIPCUEN = WS-CORTE-MEN-ANT                          00620000
                 ADD WS-SALDO TO WS-TOTAL-CMEN                          00421000
                 ADD 1        TO WS-CUENTA-CMEN                         00421000
              ELSE
      *SI PERTENECE AL MISMO CORTE MAYOR PERO OTRO MENOR
                 PERFORM 2700-CORTE-MENOR THRU F-2700-CORTE-MENOR       00620000
              END-IF                                                    00620000
           ELSE                                                         00620000
      *SI NO PERTENECE AL MISMO CORTE MAYOR
              PERFORM 2600-CORTE-MAYOR THRU F-2600-CORTE-MAYOR          00620000
           END-IF                                                       00620000
      
      *EN CUALQUIERA DE LOS CASOS ANTERIORES, SIEMPRE QUIERO IMPRIMIR EL
      *REGISTRO LEIDO Y PASAR AL SIGUIENTE
           PERFORM 6000-IMP-REGISTRO
              THRU F-6000-IMP-REGISTRO
                                                                        00620000
           PERFORM 2500-LEER     THRU F-2500-LEER                       00610000
           .                                                            00620000
                                                                        00620000
       F-2000-PROCESO. EXIT.                                            00630000
                                                                        00640000
      **************************************                            00650000
      *  LEER REGISTROS                    *                            00660000
      **************************************                            00670000
       2500-LEER.                                                       00680000
            EXEC SQL
              FETCH CURSOR-CTA
              INTO :WS-TIPCUEN,
                   :WS-NROCUEN,
                   :WS-SUCUEN,
                   :WS-NROCLI,
                   :WS-SALDO
            END-EXEC.
                                                                        00830000
           EVALUATE TRUE
      *SE LEE CON EXITO
             WHEN SQLCODE EQUAL ZEROS
                PERFORM 2510-VALIDA-LECTURA
                   THRU F-2510-VALIDA-LECTURA
                   
                ADD 1 TO WS-CANT-LEIDOS                                 00730000
      
      *SI ACABA EL CURSOR
             WHEN SQLCODE EQUAL 100
                  SET WS-ULTIMA-ITERACION TO TRUE
                  SET WS-FIN      TO TRUE                               00750000
      *Y SE LLEGO A LEER ALGUN DATO
                  IF WS-CANT-LEIDOS > 0
                     PERFORM 2600-CORTE-MAYOR THRU F-2600-CORTE-MAYOR   00620000
      *SI NO SE LEYO NINGUNO
                  ELSE
                     DISPLAY 'LA TABLA NO TIENE DATOS'                     00421
                  END-IF
      *SI SUCEDE UN ERROR
             WHEN OTHER
                  MOVE 'ERROR FETCH CUR-CLI: '
                                              TO WS-TITULO-ERROR
                  MOVE SQLCODE TO WS-SQLCODE

                  PERFORM 11000-DISPLAY-ERROR
                     THRU F-11000-DISPLAY-ERROR
                                                                        00780000
                  MOVE 9999 TO RETURN-CODE                              00790000
                  SET WS-FIN      TO TRUE                               00800000
           END-EVALUATE                                                 00820000
           .                                                            00830000
       F-2500-LEER. EXIT.                                               00840000

       2510-VALIDA-LECTURA.
           SET WS-VALIDACIONES-OK TO TRUE

           IF WS-TIPCUEN IS NUMERIC OR WS-TIPCUEN = SPACES
               MOVE 'TIPO DE CUENTA ERRONEA LEYENDO' TO WS-TITULO-ERROR
               MOVE WS-TIPCUEN TO WS-DATO-ERROR

               SET WS-VALIDACIONES-NO-OK TO TRUE

               PERFORM 11000-DISPLAY-ERROR
                  THRU F-11000-DISPLAY-ERROR
           END-IF

           IF WS-NROCUEN IS NOT NUMERIC OR WS-NROCUEN = ZEROS
               MOVE 'NRO DE CUENTA ERRONEO LEYENDO' TO WS-TITULO-ERROR
               MOVE WS-NROCUEN TO WS-DATO-ERROR

               SET WS-VALIDACIONES-NO-OK TO TRUE

               PERFORM 11000-DISPLAY-ERROR
                  THRU F-11000-DISPLAY-ERROR
           END-IF

           IF WS-SUCUEN IS NOT NUMERIC OR WS-SUCUEN = ZEROS
               MOVE 'SUCURSAL ERRONEA LEYENDO' TO WS-TITULO-ERROR
               MOVE WS-SUCUEN TO WS-DATO-ERROR

               SET WS-VALIDACIONES-NO-OK TO TRUE

               PERFORM 11000-DISPLAY-ERROR
                  THRU F-11000-DISPLAY-ERROR
           END-IF

           IF WS-NROCLI IS NOT NUMERIC OR WS-NROCLI = ZEROS
             MOVE 'NRO DE CLIENTE ERRONEO LEYENDO' TO WS-TITULO-ERROR
             MOVE WS-NROCLI TO WS-DATO-ERROR

             SET WS-VALIDACIONES-NO-OK TO TRUE

             PERFORM 11000-DISPLAY-ERROR
                THRU F-11000-DISPLAY-ERROR
           END-IF

           IF WS-SALDO IS NOT NUMERIC
             MOVE 'SALDO ERRONEO LEYENDO' TO WS-TITULO-ERROR
             MOVE WS-SALDO TO WS-DATO-ERROR

             SET WS-VALIDACIONES-NO-OK TO TRUE

             PERFORM 11000-DISPLAY-ERROR
                THRU F-11000-DISPLAY-ERROR
           END-IF

           IF WS-VALIDACIONES-NO-OK
              ADD 1 TO WS-CANT-ERRONEOS
           END-IF
           .
       F-2510-VALIDA-LECTURA. EXIT.     

       2600-CORTE-MAYOR.                                                00840000
           PERFORM 2700-CORTE-MENOR THRU F-2700-CORTE-MENOR             00620000

           PERFORM 2610-IMPRIMO-CORTE-MAYOR
              THRU F-2610-IMPRIMO-CORTE-MAYOR
      
      *ACTUALIZO EL VALOR POR EL CUAL COMPARAR EL SIGUIENTE REGISTRO
           MOVE WS-SUCUEN TO WS-CORTE-MAY-ANT
           MOVE 0 TO WS-TOTAL-CMAY
      
      *SI AUN QUEDAN REGISTROS POR LEER VUELVO A IMPRIMIR ENCABEZADOS
           IF WS-NO-ULTIMA-ITERACION
      *ESTA BANDERA SE USA PARA QUE SE CONSIERE AL HACER EL SALTO DE PAG
      *SI VA A HABER ESPACIO SUFICIENTE PARA QUE HAYA AL MENOS UN
      *REGISTRO LUEOGO DE LOS TITULOS ANTES DE QUE SE ACABE LA PAG NUEVA
              SET WS-ES-SALTO-ALT TO TRUE

              PERFORM 8000-IMP-ENCABEZ-SUC
                 THRU F-8000-IMP-ENCABEZ-SUC

              MOVE WS-ENCABEZ TO REG-SALIDA

              PERFORM 8500-IMPACTO-IMPR
                 THRU F-8500-IMPACTO-IMPR
           END-IF
           .
       F-2600-CORTE-MAYOR. EXIT.                                        00840000

       2610-IMPRIMO-CORTE-MAYOR.                                        00840000
      *ELIMINO DATOS BASURA
           INITIALIZE WS-RENGLON-CORTE-MAYOR

           MOVE WS-CUENTA-CMAY TO WS-RENGLON-CMAY-CANT
           MOVE WS-TOTAL-CMAY TO WS-RENGLON-CMAY-SALD

           MOVE 0 TO WS-CUENTA-CMAY

           MOVE WS-RENGLON-CORTE-MAYOR TO REG-SALIDA

           PERFORM 8500-IMPACTO-IMPR
              THRU F-8500-IMPACTO-IMPR
           .
       F-2610-IMPRIMO-CORTE-MAYOR. EXIT.

       2700-CORTE-MENOR.                                                00620000
           PERFORM 2710-IMPRIMO-CORTE-MENOR
              THRU F-2710-IMPRIMO-CORTE-MENOR
      
      *ACTUALIZO EL VALOR POR EL CUAL COMPARAR EL PROXIMO REGISTRO
           MOVE WS-TIPCUEN    TO WS-CORTE-MEN-ANT

           ADD WS-TOTAL-CMEN  TO WS-TOTAL-CMAY
           MOVE WS-SALDO TO WS-TOTAL-CMEN

           ADD WS-CUENTA-CMEN TO WS-CUENTA-CMAY
           MOVE 1        TO WS-CUENTA-CMEN
           .
       F-2700-CORTE-MENOR. EXIT.                                        00850000

       2710-IMPRIMO-CORTE-MENOR.
           INITIALIZE WS-RENGLON-CORTE-MENOR

           EVALUATE WS-TIPCUEN
              WHEN 01
                 MOVE 'CAJA DE AHORROS' TO WS-RENGLON-CMEN-NOMBRE
              WHEN 02
                 MOVE 'CUENTAS CORRIENTES' TO WS-RENGLON-CMEN-NOMBRE
              WHEN 03
                 MOVE 'PLAZO FIJO' TO WS-RENGLON-CMEN-NOMBRE
              WHEN OTHER
                 DISPLAY 'TIPO DE CUENTA ERRONEA'
           END-EVALUATE

           MOVE WS-TOTAL-CMEN TO WS-RENGLON-CMEN-SALDO
           MOVE WS-RENGLON-CORTE-MENOR TO REG-SALIDA

           PERFORM 8500-IMPACTO-IMPR
              THRU F-8500-IMPACTO-IMPR
           .
       F-2710-IMPRIMO-CORTE-MENOR. EXIT.

       6000-IMP-REGISTRO.
           INITIALIZE WS-REG-SALIDA

           MOVE WS-TIPCUEN TO                 WS-SALIDA-TIPCUEN
           MOVE WS-NROCUEN TO                 WS-SALIDA-NROCUEN
           MOVE WS-NROCLI  TO                 WS-SALIDA-NROCLI
           MOVE WS-SALDO   TO                 WS-SALIDA-SALDO

           MOVE WS-REG-SALIDA TO REG-SALIDA

           PERFORM 8500-IMPACTO-IMPR
              THRU F-8500-IMPACTO-IMPR
           .
       F-6000-IMP-REGISTRO. EXIT.

       7000-IMP-TITULOS.
           MOVE WS-CUENTA-PAGINA TO WS-NRO-PAGINA
           MOVE WS-TITULO TO REG-SALIDA

           SET WS-ES-TITULO TO TRUE

           MOVE 'GR' TO WS-OP-GR-CL-FS

           WRITE REG-SALIDA AFTER PAGE

           PERFORM 9000-VAL-SAL-FS
              THRU F-9000-VAL-SAL-FS

           MOVE SPACES TO REG-SALIDA

           ADD 1 TO WS-CUENTA-PAGINA
           MOVE 1 TO WS-CUENTA-LINEA
           .
       F-7000-IMP-TITULOS. EXIT.

       8000-IMP-ENCABEZ-SUC.
           INITIALIZE WS-ENCABEZ-SUC-NUM

           MOVE WS-SUCUEN TO WS-ENCABEZ-SUC-NUM
           MOVE WS-ENCABEZ-SUC TO REG-SALIDA

           PERFORM 8500-IMPACTO-IMPR
              THRU F-8500-IMPACTO-IMPR
           .
       F-8000-IMP-ENCABEZ-SUC. EXIT.

       8500-IMPACTO-IMPR.
           MOVE 'GR' TO WS-OP-GR-CL-FS

      *SI ES NECESARIO UN SALTO DE LINEA
           IF WS-CUENTA-LINEA > WS-MAX-LINEAS
            OR (
                WS-ES-SALTO-ALT
            AND WS-CUENTA-LINEA > WS-MAX-LINEAS-CABEZ
               )
      *COMO EN EL 7000-IMP-TITULOS PISO LOS DATOS DEL REG-SALIDA
      *GUARDO LOS DATOS EN UNA VARIABLE TEMPORAL
              MOVE REG-SALIDA TO WS-GUARDO-DATOS-IMPRESION
      *LIMPIO LA SALIDA
              MOVE SPACES TO REG-SALIDA

              PERFORM 7000-IMP-TITULOS
                 THRU F-7000-IMP-TITULOS
      
      *RESETEO BANDERA TRAS SU UTILIZACION
              SET WS-NO-ES-SALTO-ALT TO TRUE
      *RECUPERO LOS DATOS DE LA VARIABLE TEMPORAL
              MOVE WS-GUARDO-DATOS-IMPRESION TO REG-SALIDA
      *LIMPIO VARIABLE TEMPORAL
              MOVE SPACES TO WS-GUARDO-DATOS-IMPRESION
           END-IF

           ADD 1 TO WS-CUENTA-LINEA

           WRITE REG-SALIDA
           PERFORM 9000-VAL-SAL-FS
              THRU F-9000-VAL-SAL-FS
              
      *LIMPIO LA SALIDA
           MOVE SPACES TO REG-SALIDA

           MOVE 'GR' TO WS-OP-GR-CL-FS

           IF WS-CUENTA-LINEA > WS-MAX-LINEAS
              PERFORM 7000-IMP-TITULOS
                 THRU F-7000-IMP-TITULOS
           ELSE
      *IMPRIMO RENGLON EN BLANCO (REQUERIDO EN ESPECIFICACIONES DEL PGM)     
              WRITE REG-SALIDA
              PERFORM 9000-VAL-SAL-FS
                 THRU F-9000-VAL-SAL-FS

              ADD 1 TO WS-CUENTA-LINEA
           END-IF
           .
       F-8500-IMPACTO-IMPR. EXIT.

       9000-VAL-SAL-FS.                                                 00850000
      *SI HAY UN ERROR AL INTERACTUAR CON EL ARCHIVO DE SALIDA  
           IF WS-FILE-SAL IS NOT EQUAL '00'
