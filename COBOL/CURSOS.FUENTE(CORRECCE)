            EXEC SQL
              INCLUDE TBCURCTA
            END-EXEC.

            EXEC SQL
              DECLARE CURSOR-CTA CURSOR FOR
              SELECT TIPCUEN,
                     NROCUEN,
                     SUCUEN,
                     NROCLI,
                     SALDO,
                     FECSAL
                  FROM KC02803.TBCURCTA
                  WHERE FECSAL < '2025-06-05'
                ORDER BY SUCUEN, TIPCUEN
            END-EXEC.

