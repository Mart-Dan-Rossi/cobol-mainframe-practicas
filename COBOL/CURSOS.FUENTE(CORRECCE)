             IF WS-OP-GR-CL-FS = 'OP'
               MOVE 'ERROR ABRIENDO ARCHIVO SALIDA: ' TO WS-TITULO-ERROR
             ELSE IF WS-OP-GR-CL-FS = 'GR'
               MOVE 'ERROR GRABANDO ARCHIVO SALIDA: ' TO WS-TITULO-ERROR
             ELSE IF WS-OP-GR-CL-FS = 'CL'
               MOVE 'ERROR CERRANDO ARCHIVO SALIDA: ' TO WS-TITULO-ERROR
             ELSE
      *EVITA QUE SE LLAME LA FUNCION SIN HABER ASIGNADO VALOR A
      *LA VARIABLE DE CONTROL (PREVENSION DE ERRORES FUTUROS)       
               MOVE 'FALTA WS-OP-GR-CL-FS EN OP O CL DE SALIDA'
                                                      TO WS-TITULO-ERROR
             END-IF

             MOVE WS-FILE-SAL TO WS-DATO-ERROR

             PERFORM 11000-DISPLAY-ERROR
                THRU F-11000-DISPLAY-ERROR

             MOVE 9999 TO RETURN-CODE
             SET WS-FIN TO TRUE
           ELSE
             ADD 1 TO WS-CANT-IMPRESOS
           END-IF
