       2600-EVAL-DUP.
           EVALUATE WS-NOMBRE-TABLA
            WHEN 'CLI'
      *EVALUO CLAVE
                IF WT-NROCLI = WS-CLI-KEY-ANT
                   ADD 1 TO WS-CANT-CLI-DUP
      *LIMPIO LA MASCARA DE SALIDA
                   INITIALIZE WS-REG-SALIDA-CLI
      *MUEVO EL MENSAJE DE ERROR A LA MASCARA
                   MOVE WS-MSJ-ERR-CLI-DUP TO WS-REG-S-I-DESC-ERR

                   SET WS-CLI-DUP TO TRUE

                   PERFORM 6000-GRABAR-SALIDA
                      THRU F-6000-GRABAR-SALIDA
                ELSE
                   SET WS-CLI-NO-DUP TO TRUE
                   MOVE WT-NROCLI TO WS-CLI-KEY-ANT
                END-IF
           WHEN 'CTA'
      *EVALUO CLAVE
                IF WS-TIPCUEN = WS-CTA-KEY-ANT-TIPCUEN
                 AND WS-NROCUEN = WS-CTA-KEY-ANT-NROCUEN
                 AND WS-SUCUEN = WS-CTA-KEY-ANT-SUCUEN
                   ADD 1 TO WS-CANT-CTA-DUP
      *LIMPIO LA MASCARA DE SALIDA
                   INITIALIZE WS-REG-SALIDA-CTA
      *MUEVO EL MENSAJE DE ERROR A LA MASCARA
                   MOVE WS-MSJ-ERR-CTA-DUP TO WS-REG-S-A-DESC-ERR

                   SET WS-CTA-DUP TO TRUE

                   PERFORM 6000-GRABAR-SALIDA
                      THRU F-6000-GRABAR-SALIDA
                ELSE
                   SET WS-CTA-NO-DUP TO TRUE
                   MOVE WS-TIPCUEN TO WS-CTA-KEY-ANT-TIPCUEN
                   MOVE WS-NROCUEN TO WS-CTA-KEY-ANT-NROCUEN
                   MOVE WS-SUCUEN TO WS-CTA-KEY-ANT-SUCUEN
                END-IF
           WHEN OTHER
                PERFORM 2610-ERROR-EN-EVAL
                   THRU F-2610-ERROR-EN-EVAL
           END-EVALUATE
           .
       F-2600-EVAL-DUP. EXIT.

